# =========================================================================
# Dietrix — environment variables template
# Copy this file to `.env` and fill in real values. Never commit the .env file.
# =========================================================================

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Dietrix
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_POOL_SIZE=30

# ---- Mail (SMTP) ----
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=change-me

# ---- JWT ----
# Use a long random string (>= 256 bits). Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits
JWT_ACCESS_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000

# ---- Application ----
# Timezone for "today" calculations (daily water/meal counters reset at local midnight)
APP_TIMEZONE=Asia/Almaty

# ---- CORS ----
# Comma-separated list of exact origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://dietrix-front.vercel.app
# Comma-separated regex patterns (e.g. for Vercel preview deployments)
CORS_ALLOWED_ORIGIN_PATTERNS=https://dietrix-front-.*\.vercel\.app

# ---- Firebase Cloud Messaging (push notifications) ----
FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT=

